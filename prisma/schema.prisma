generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String              @id @default(uuid())
  name       String              @unique
  code       String              @unique
  isAcademic Boolean             @default(true)
  createdAt  DateTime            @default(now())
  alumni     Alumni[]
  history    AttendanceHistory[]
  faculty    Faculty[]
  labBatches LabBatch[]
  students   Student[]
  subjects   Subject[]
  timetables Timetable[]
  users      User[]
  sections   Section[]           @relation("DepartmentToSection")
}

model Section {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  createdAt             DateTime                @default(now())
  history               AttendanceHistory[]
  labBatches            LabBatch[]
  students              Student[]
  timetables            Timetable[]
  departments           Department[]            @relation("DepartmentToSection")
  FacultySubjectMapping FacultySubjectMapping[]
}

model User {
  id                    String                 @id @default(uuid())
  username              String                 @unique
  password              String
  role                  String                 @default("USER")
  departmentId          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  facultyId             String?                @unique
  downloads             AttendanceHistory[]
  passwordResetRequests PasswordResetRequest[]
  smsLogs               SMSLog[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  faculty               Faculty?               @relation(fields: [facultyId], references: [id])
  internalMarks         InternalMark[]
}

model Faculty {
  id                    String                  @id @default(uuid())
  empCode               String                  @unique
  empName               String
  shortName             String?
  dob                   DateTime
  gender                String
  joinDate              DateTime
  resignDate            DateTime?
  departmentId          String
  designation           String
  mobile                String
  email                 String?
  bloodGroup            String?
  basicSalary           Float?
  fatherName            String?
  motherName            String?
  address               String?
  qualification         String?
  aadharNo              String?
  panNo                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  department            Department              @relation(fields: [departmentId], references: [id])
  user                  User?
  FacultySubjectMapping FacultySubjectMapping[]
  FeedbackResponse      FeedbackResponse[]
}

model Student {
  id                    String               @id @default(uuid())
  rollNumber            String               @unique
  name                  String
  mobile                String
  year                  String
  semester              String
  batchString           String?              @map("batch")
  sectionId             String
  departmentId          String
  regulationId          String?
  batchId               String?
  isDetained            Boolean              @default(false)
  originalBatchId       String?
  labBatchId            String?
  photoUrl              String?
  hallTicketNumber      String?              @unique
  eamcetRank            String?
  dateOfBirth           DateTime?
  dateOfReporting       DateTime?
  gender                String?
  caste                 String?
  casteName             String?
  category              String?
  admissionType         String?
  fatherName            String?
  motherName            String?
  address               String?
  studentContactNumber  String?
  emailId               String?
  aadharNumber          String?
  abcId                 String?
  reimbursement         Boolean              @default(false)
  isLateralEntry        Boolean              @default(false)
  certificatesSubmitted Boolean              @default(false)
  domainMailId          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  examApplications      ExamApplication[]
  smsLogs               SMSLog[]
  results               SemesterResult[]
  batch                 Batch?               @relation("CurrentBatch", fields: [batchId], references: [id])
  department            Department           @relation(fields: [departmentId], references: [id])
  labBatch              LabBatch?            @relation(fields: [labBatchId], references: [id])
  originalBatch         Batch?               @relation("OriginalBatch", fields: [originalBatchId], references: [id])
  regulation            Regulation?          @relation(fields: [regulationId], references: [id])
  section               Section              @relation(fields: [sectionId], references: [id])
  subjects              Subject[]            @relation("StudentToSubject")
  internalMarks         InternalMark[]
  FeedbackSubmission    FeedbackSubmission[]
}

model SemesterResult {
  id        String   @id @default(uuid())
  studentId String
  year      String
  semester  String
  sgpa      String
  cgpa      String
  grades    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, year, semester])
}

model Regulation {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  students  Student[]
  subjects  Subject[]
}

model Subject {
  id                    String                   @id @default(uuid())
  name                  String
  code                  String
  year                  String
  semester              String
  type                  String
  isElective            Boolean                  @default(false)
  regulationId          String?
  electiveSlotId        String?
  departmentId          String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  shortName             String?
  history               AttendanceHistory[]
  examAppSubjects       ExamApplicationSubject[]
  department            Department               @relation(fields: [departmentId], references: [id])
  electiveSlotRelation  ElectiveSlot?            @relation(fields: [electiveSlotId], references: [id])
  regulation            Regulation?              @relation(fields: [regulationId], references: [id])
  timetables            Timetable[]
  students              Student[]                @relation("StudentToSubject")
  internalMarks         InternalMark[]
  FacultySubjectMapping FacultySubjectMapping[]
  FeedbackResponse      FeedbackResponse[]
}

model Period {
  id         String              @id @default(uuid())
  name       String
  startTime  String
  endTime    String
  order      Int
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  history    AttendanceHistory[]
  timetables Timetable[]
}

model AttendanceHistory {
  id             String        @id @default(uuid())
  date           DateTime      @default(now())
  year           String
  semester       String
  sectionId      String
  departmentId   String
  academicYearId String?
  subjectId      String?
  periodId       String?
  status         String
  type           String        @default("ACADEMIC")
  fileName       String?
  downloadedBy   String
  details        String        @default("[]")
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  department     Department    @relation(fields: [departmentId], references: [id])
  user           User          @relation(fields: [downloadedBy], references: [id])
  period         Period?       @relation(fields: [periodId], references: [id])
  section        Section       @relation(fields: [sectionId], references: [id])
  subject        Subject?      @relation(fields: [subjectId], references: [id])

  @@unique([date, sectionId, periodId, year, departmentId], name: "unique_attendance")
}

model Alumni {
  id           String      @id @default(uuid())
  rollNumber   String      @unique
  name         String
  mobile       String
  passingYear  String
  departmentId String?
  createdAt    DateTime    @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
}

model ElectiveSlot {
  id         String      @id @default(uuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  subjects   Subject[]
  timetables Timetable[]
}

model AcademicYear {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  startDate             DateTime
  endDate               DateTime
  isCurrent             Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  attendanceHistory     AttendanceHistory[]
  internalMarks         InternalMark[]
  FacultySubjectMapping FacultySubjectMapping[]
  FeedbackForm          FeedbackForm[]
}

model Batch {
  id               String    @id @default(uuid())
  name             String    @unique
  startYear        Int
  endYear          Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  students         Student[] @relation("CurrentBatch")
  detainedStudents Student[] @relation("OriginalBatch")
}

model LabBatch {
  id           String      @id @default(uuid())
  name         String
  sectionId    String
  departmentId String
  year         String
  semester     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department  @relation(fields: [departmentId], references: [id])
  section      Section     @relation(fields: [sectionId], references: [id])
  students     Student[]
  timetables   Timetable[]

  @@unique([departmentId, year, semester, sectionId, name])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  details     String
  performedBy String
  createdAt   DateTime @default(now())
}

model PasswordResetRequest {
  id         String   @id @default(uuid())
  userId     String
  status     String   @default("PENDING")
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model SMSLog {
  id              String   @id @default(uuid())
  studentId       String
  sentById        String
  dateSent        DateTime @default(now())
  targetDate      DateTime
  mobileNumber    String
  messageType     String   @default("ABSENTEE_ALERT")
  status          String   @default("PENDING")
  gatewayResponse String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sentBy          User     @relation(fields: [sentById], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])
}

model Timetable {
  id             String        @id @default(uuid())
  departmentId   String
  year           String
  semester       String
  sectionId      String
  subjectId      String?
  dayOfWeek      Int
  periodId       String
  validFrom      DateTime
  validTo        DateTime?
  isLab          Boolean       @default(false)
  isLunch        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  electiveSlotId String?
  labBatchId     String?
  department     Department    @relation(fields: [departmentId], references: [id])
  electiveSlot   ElectiveSlot? @relation(fields: [electiveSlotId], references: [id])
  labBatch       LabBatch?     @relation(fields: [labBatchId], references: [id])
  period         Period        @relation(fields: [periodId], references: [id])
  section        Section       @relation(fields: [sectionId], references: [id])
  subject        Subject?      @relation(fields: [subjectId], references: [id])

  @@index([departmentId, year, semester, sectionId])
  @@index([validFrom, validTo])
}

model ExamApplication {
  id                 String                   @id @default(uuid())
  studentId          String
  rollNumber         String
  department         String
  year               String
  semester           String
  utrNumber          String
  paymentScreenshot  String?
  duplicateUtr       Boolean                  @default(false)
  duplicateUtrRollNo String?
  status             String                   @default("PENDING")
  remarks            String?
  approvedBy         String?
  paymentDate        DateTime?
  submittedAt        DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  amountPaid         Float?
  student            Student                  @relation(fields: [studentId], references: [id])
  subjects           ExamApplicationSubject[]
  editRequested      Boolean                  @default(false)
  editRequestReason  String?
}

model ExamApplicationSubject {
  id            String          @id @default(uuid())
  applicationId String
  subjectId     String
  application   ExamApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id])
}

model ExamApplicationSetting {
  id             String    @id @default(uuid())
  year           String
  semester       String
  startDate      DateTime
  endDate        DateTime
  lateFeeEndDate DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([year, semester])
}

model InternalMark {
  id             String   @id @default(uuid())
  studentId      String
  subjectId      String
  academicYearId String
  marksObtained  Float
  maxMarks       Float    @default(30)
  recordedById   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  recordedBy   User         @relation(fields: [recordedById], references: [id])

  @@unique([studentId, subjectId, academicYearId])
}

model FacultySubjectMapping {
  id             String   @id @default(uuid())
  facultyId      String
  subjectId      String
  sectionId      String
  academicYearId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  faculty      Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectId, sectionId, academicYearId], name: "unique_faculty_mapping")
}

model FeedbackQuestion {
  id        String   @id @default(uuid())
  text      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeedbackForm {
  id             String   @id @default(uuid())
  title          String
  description    String?
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions  FeedbackSubmission[]
  responses    FeedbackResponse[]
  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id])
}

model FeedbackSubmission {
  id          String   @id @default(uuid())
  formId      String
  studentId   String
  submittedAt DateTime @default(now())

  form    FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([formId, studentId], name: "unique_student_submission")
}

model FeedbackResponse {
  id            String   @id @default(uuid())
  formId        String
  facultyId     String
  subjectId     String
  ratings       Json
  comments      String?
  overallRating Float
  createdAt     DateTime @default(now())

  form    FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  faculty Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}
