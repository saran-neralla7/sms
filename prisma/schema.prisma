generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String              @id @default(uuid())
  name       String              @unique
  code       String              @unique
  isAcademic Boolean             @default(true)
  createdAt  DateTime            @default(now())
  alumni     Alumni[]
  history    AttendanceHistory[]
  faculty    Faculty[]
  labBatches LabBatch[]
  students   Student[]
  subjects   Subject[]
  timetables Timetable[]
  users      User[]
  sections   Section[]           @relation("DepartmentToSection")
  feedbackForms FeedbackForm[]
}

model Section {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  createdAt             DateTime                @default(now())
  history               AttendanceHistory[]
  labBatches            LabBatch[]
  students              Student[]
  timetables            Timetable[]
  departments           Department[]            @relation("DepartmentToSection")
  FacultySubjectMapping FacultySubjectMapping[]
  feedbackForms         FeedbackForm[]          @relation("FeedbackFormSections")
  midExamPapers         MidExamPaper[]
}

model User {
  id                    String                 @id @default(uuid())
  username              String                 @unique
  password              String
  role                  String                 @default("USER")
  departmentId          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  facultyId             String?                @unique
  downloads             AttendanceHistory[]
  passwordResetRequests PasswordResetRequest[]
  smsLogs               SMSLog[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  faculty               Faculty?               @relation(fields: [facultyId], references: [id])
  internalMarks         InternalMark[]
  issuedCertificates    Certificate[]
}

model Faculty {
  id                    String                  @id @default(uuid())
  empCode               String                  @unique
  empName               String
  shortName             String?
  dob                   DateTime
  gender                String
  joinDate              DateTime
  resignDate            DateTime?
  departmentId          String
  designation           String
  mobile                String
  email                 String?
  bloodGroup            String?
  basicSalary           Float?
  fatherName            String?
  motherName            String?
  address               String?
  qualification         String?
  aadharNo              String?
  panNo                 String?
  photoUrl              String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  department            Department              @relation(fields: [departmentId], references: [id])
  user                  User?
  FacultySubjectMapping FacultySubjectMapping[]
  FeedbackResponse      FeedbackResponse[]
}

model Student {
  id                    String               @id @default(uuid())
  rollNumber            String               @unique
  name                  String
  mobile                String
  year                  String
  semester              String
  batchString           String?              @map("batch")
  sectionId             String
  departmentId          String
  regulationId          String?
  batchId               String?
  isDetained            Boolean              @default(false)
  isAlumni              Boolean              @default(false)
  alumniId              String?              // links to Alumni.id after graduation
  originalBatchId       String?
  labBatchId            String?
  photoUrl              String?
  hallTicketNumber      String?              @unique
  eamcetRank            String?
  dateOfBirth           DateTime?
  dateOfReporting       DateTime?
  gender                String?
  caste                 String?
  casteName             String?
  category              String?
  admissionType         String?
  nationality           String?
  religion              String?
  fatherName            String?
  motherName            String?
  address               String?
  studentContactNumber  String?
  emailId               String?
  aadharNumber          String?
  abcId                 String?
  reimbursement         Boolean              @default(false)
  isLateralEntry        Boolean              @default(false)
  certificatesSubmitted Boolean              @default(false)
  domainMailId          String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  examApplications      ExamApplication[]
  smsLogs               SMSLog[]
  results               SemesterResult[]
  batch                 Batch?               @relation("CurrentBatch", fields: [batchId], references: [id])
  department            Department           @relation(fields: [departmentId], references: [id])
  labBatch              LabBatch?            @relation(fields: [labBatchId], references: [id])
  originalBatch         Batch?               @relation("OriginalBatch", fields: [originalBatchId], references: [id])
  regulation            Regulation?          @relation(fields: [regulationId], references: [id])
  section               Section              @relation(fields: [sectionId], references: [id])
  subjects              Subject[]            @relation("StudentToSubject")
  internalMarks         InternalMark[]
  FeedbackSubmission    FeedbackSubmission[]
  certificates          Certificate[]
  midExamEntries        MidExamMarksEntry[]
  assignmentMarks       AssignmentMark[]
}

model SemesterResult {
  id        String   @id @default(uuid())
  studentId String
  year      String
  semester  String
  sgpa      String
  cgpa      String
  grades    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, year, semester])
}

model Regulation {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  students  Student[]
  subjects  Subject[]
}

model Subject {
  id                    String                   @id @default(uuid())
  name                  String
  code                  String
  year                  String
  semester              String
  type                  String
  isElective            Boolean                  @default(false)
  regulationId          String?
  electiveSlotId        String?
  departmentId          String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  shortName             String?
  history               AttendanceHistory[]
  examAppSubjects       ExamApplicationSubject[]
  department            Department               @relation(fields: [departmentId], references: [id])
  electiveSlotRelation  ElectiveSlot?            @relation(fields: [electiveSlotId], references: [id])
  regulation            Regulation?              @relation(fields: [regulationId], references: [id])
  timetables            Timetable[]
  students              Student[]                @relation("StudentToSubject")
  internalMarks         InternalMark[]
  FacultySubjectMapping FacultySubjectMapping[]
  FeedbackResponse      FeedbackResponse[]
  midExamPapers         MidExamPaper[]
  assignmentMarks       AssignmentMark[]
}

model Period {
  id         String              @id @default(uuid())
  name       String
  startTime  String
  endTime    String
  order      Int
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  history    AttendanceHistory[]
  timetables Timetable[]
}

model AttendanceHistory {
  id             String        @id @default(uuid())
  date           DateTime      @default(now())
  year           String
  semester       String
  sectionId      String
  departmentId   String
  academicYearId String?
  subjectId      String?
  periodId       String?
  status         String
  type           String        @default("ACADEMIC")
  fileName       String?
  downloadedBy   String
  details        String        @default("[]")
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  department     Department    @relation(fields: [departmentId], references: [id])
  user           User          @relation(fields: [downloadedBy], references: [id])
  period         Period?       @relation(fields: [periodId], references: [id])
  section        Section       @relation(fields: [sectionId], references: [id])
  subject        Subject?      @relation(fields: [subjectId], references: [id])

  @@unique([date, sectionId, periodId, year, departmentId], name: "unique_attendance")
}

model Alumni {
  id              String       @id @default(uuid())
  rollNumber      String       @unique
  name            String
  mobile          String
  passingYear     String       // e.g. "2026" — derived from graduation year
  graduationDate  DateTime?    // actual date student left the institution
  dateOfReporting DateTime?    // original join date
  dateOfBirth     DateTime?
  fatherName      String?
  nationality     String?
  religion        String?
  category        String?
  casteName       String?
  batchId         String?      // which batch they graduated from
  academicYearId  String?      // which academic year they graduated in
  departmentId    String?
  createdAt       DateTime     @default(now())
  department      Department?  @relation(fields: [departmentId], references: [id])
  batch           Batch?       @relation(fields: [batchId], references: [id])
  academicYear    AcademicYear? @relation(fields: [academicYearId], references: [id])
}

model ElectiveSlot {
  id         String      @id @default(uuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  subjects   Subject[]
  timetables Timetable[]
}

model AcademicYear {
  id                      String                    @id @default(uuid())
  name                    String                    @unique
  startDate               DateTime
  endDate                 DateTime
  isCurrent               Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  attendanceHistory       AttendanceHistory[]
  internalMarks           InternalMark[]
  FacultySubjectMapping   FacultySubjectMapping[]
  FeedbackForm            FeedbackForm[]
  alumni                  Alumni[]
  examSettings            ExamApplicationSetting[]
  midExamPapers           MidExamPaper[]
  assignmentMarks         AssignmentMark[]
}

model Batch {
  id               String    @id @default(uuid())
  name             String    @unique
  startYear        Int
  endYear          Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  students         Student[] @relation("CurrentBatch")
  detainedStudents Student[] @relation("OriginalBatch")
  feedbackForms    FeedbackForm[]
  alumni           Alumni[]
}

model LabBatch {
  id           String      @id @default(uuid())
  name         String
  sectionId    String
  departmentId String
  year         String
  semester     String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department  @relation(fields: [departmentId], references: [id])
  section      Section     @relation(fields: [sectionId], references: [id])
  students     Student[]
  timetables   Timetable[]

  @@unique([departmentId, year, semester, sectionId, name])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  details     String
  performedBy String
  createdAt   DateTime @default(now())
}

model PasswordResetRequest {
  id         String   @id @default(uuid())
  userId     String
  status     String   @default("PENDING")
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model SMSLog {
  id              String   @id @default(uuid())
  studentId       String
  sentById        String
  dateSent        DateTime @default(now())
  targetDate      DateTime
  mobileNumber    String
  messageType     String   @default("ABSENTEE_ALERT")
  status          String   @default("PENDING")
  gatewayResponse String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sentBy          User     @relation(fields: [sentById], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])
}

model Timetable {
  id             String        @id @default(uuid())
  departmentId   String
  year           String
  semester       String
  sectionId      String
  subjectId      String?
  dayOfWeek      Int
  periodId       String
  validFrom      DateTime
  validTo        DateTime?
  isLab          Boolean       @default(false)
  isLunch        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  electiveSlotId String?
  labBatchId     String?
  department     Department    @relation(fields: [departmentId], references: [id])
  electiveSlot   ElectiveSlot? @relation(fields: [electiveSlotId], references: [id])
  labBatch       LabBatch?     @relation(fields: [labBatchId], references: [id])
  period         Period        @relation(fields: [periodId], references: [id])
  section        Section       @relation(fields: [sectionId], references: [id])
  subject        Subject?      @relation(fields: [subjectId], references: [id])

  @@index([departmentId, year, semester, sectionId])
  @@index([validFrom, validTo])
}

model ExamApplication {
  id                 String                   @id @default(uuid())
  studentId          String
  rollNumber         String
  department         String
  year               String
  semester           String
  utrNumber          String
  paymentScreenshot  String?
  duplicateUtr       Boolean                  @default(false)
  duplicateUtrRollNo String?
  status             String                   @default("PENDING")
  remarks            String?
  approvedBy         String?
  paymentDate        DateTime?
  submittedAt        DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  amountPaid         Float?
  payments           Json?                    // Array of { utrNumber: string, amountPaid: number, paymentDate: string }
  student            Student                  @relation(fields: [studentId], references: [id])
  subjects           ExamApplicationSubject[]
  editRequested      Boolean                  @default(false)
  editRequestReason  String?
  type               String                   @default("REGULAR") // REGULAR or SUPPLY
  settingId          String?
  setting            ExamApplicationSetting?  @relation(fields: [settingId], references: [id], onDelete: SetNull)
}

model ExamApplicationSubject {
  id            String          @id @default(uuid())
  applicationId String
  subjectId     String
  application   ExamApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  subject       Subject         @relation(fields: [subjectId], references: [id])
}

model ExamApplicationSetting {
  id             String            @id @default(uuid())
  name           String?           // e.g. "April 2026 Exams"
  type           String            @default("REGULAR") // REGULAR or SUPPLY
  year           String
  semester       String
  startDate      DateTime
  endDate        DateTime
  lateFeeEndDate DateTime?
  isActive       Boolean           @default(true)
  academicYearId String?           // links to academic year
  regularFee     String?           // Fee for regular semesters
  circularFileUrl String?          // Uploaded circular PDF or Image

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  applications   ExamApplication[]
  academicYear   AcademicYear?     @relation(fields: [academicYearId], references: [id])
}

model InternalMark {
  id             String   @id @default(uuid())
  studentId      String
  subjectId      String
  academicYearId String
  examType       String   @default("MID_I") // MID_I or MID_II
  marksObtained  Float
  maxMarks       Float    @default(30)
  recordedById   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  recordedBy   User         @relation(fields: [recordedById], references: [id])

  @@unique([studentId, subjectId, academicYearId, examType])
}

model FacultySubjectMapping {
  id             String   @id @default(uuid())
  facultyId      String
  subjectId      String
  sectionId      String
  academicYearId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  faculty      Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectId, sectionId, academicYearId], name: "unique_faculty_mapping")
}

model FeedbackTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("FACULTY_MAPPED") // FACULTY_MAPPED or GENERAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   FeedbackQuestion[]
  forms       FeedbackForm[]
}

model FeedbackQuestion {
  id          String   @id @default(uuid())
  templateId  String
  text        String
  type        String   @default("SCALE_1_5") // SCALE_1_5 or TEXT
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  template    FeedbackTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model FeedbackForm {
  id             String   @id @default(uuid())
  templateId     String
  title          String
  description    String?
  academicYearId String
  targetYear     Int?
  targetSemester Int?
  targetDepartmentId String?
  targetBatchId  String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  template     FeedbackTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id])
  targetDepartment Department?      @relation(fields: [targetDepartmentId], references: [id])
  targetBatch  Batch?               @relation(fields: [targetBatchId], references: [id])
  submissions  FeedbackSubmission[]
  responses    FeedbackResponse[]
  targetSections Section[]            @relation("FeedbackFormSections")
}

model FeedbackSubmission {
  id          String   @id @default(uuid())
  formId      String
  studentId   String
  submittedAt DateTime @default(now())

  form    FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([formId, studentId], name: "unique_student_submission")
}

model FeedbackResponse {
  id            String   @id @default(uuid())
  formId        String
  facultyId     String?
  subjectId     String?
  ratings       Json
  comments      String?
  overallRating Float
  createdAt     DateTime @default(now())

  form    FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  faculty Faculty?     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject Subject?     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model CertificateCounter {
  id              String   @id @default(uuid())
  certificateType String   @unique // e.g., "TC"
  currentNumber   Int
  updatedAt       DateTime @updatedAt
}

model Certificate {
  id              String   @id @default(uuid())
  studentId       String
  certificateNo   Int
  certificateType String   @default("TC")
  isDuplicate     Boolean  @default(false)
  issuedById      String
  issuedAt        DateTime @default(now())
  fileUrl         String

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  issuedBy        User     @relation(fields: [issuedById], references: [id])

  @@unique([certificateType, certificateNo], name: "unique_certificate_number")
}

// ============================================================
// MID EXAM + INTERNAL ASSESSMENT MODULE (Additive — Safe)
// ============================================================

// Configurable evaluation scheme (theory vs lab, scaling rules)
model EvaluationScheme {
  id             String   @id @default(uuid())
  name           String   // e.g. "Theory", "Lab", "Open Elective"
  subjectType    String   // THEORY | LAB | OPEN_ELECTIVE | PE_LAB
  mid1MaxMarks   Float    @default(30)
  mid2MaxMarks   Float    @default(30)
  mid1ScaledTo   Float    @default(20)
  mid2ScaledTo   Float    @default(20)
  assignmentMax  Float    @default(10)
  internalMax    Float    @default(30)  // final internal total
  isDefault      Boolean  @default(false)
  departmentId   String?  // null = global
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  papers         MidExamPaper[]
}

// Question paper per subject/section/examType
model MidExamPaper {
  id               String   @id @default(uuid())
  academicYearId   String
  departmentId     String
  year             String
  semester         String
  sectionId        String
  subjectId        String
  examType         String   // MID_I | MID_II
  schemeId         String?
  totalMarks       Float    @default(30)
  isFrozen         Boolean  @default(false)
  frozenAt         DateTime?
  frozenById       String?
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academicYear     AcademicYear         @relation(fields: [academicYearId], references: [id])
  subject          Subject              @relation(fields: [subjectId], references: [id])
  section          Section              @relation(fields: [sectionId], references: [id])
  scheme           EvaluationScheme?    @relation(fields: [schemeId], references: [id])
  questions        MidExamQuestion[]
  marksEntries     MidExamMarksEntry[]
  publishRecord    MidExamPublish?

  @@unique([academicYearId, departmentId, year, semester, sectionId, subjectId, examType])
  @@index([academicYearId, departmentId, year, semester, sectionId])
}

// Top-level questions (Q1, Q2, Q3...)
model MidExamQuestion {
  id          String   @id @default(uuid())
  paperId     String
  questionNo  Int      // 1, 2, 3...
  isCompulsory Boolean @default(true)
  choiceGroupId String? // groups questions for OR logic
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paper        MidExamPaper       @relation(fields: [paperId], references: [id], onDelete: Cascade)
  choiceGroup  MidExamChoiceGroup? @relation(fields: [choiceGroupId], references: [id])
  subQuestions MidExamSubQuestion[]

  @@unique([paperId, questionNo])
}

// Choice groups for OR logic (Q2 OR Q3 = one group)
model MidExamChoiceGroup {
  id        String   @id @default(uuid())
  paperId   String
  groupNo   Int      // 1, 2... (group 1 = Q2 OR Q3, group 2 = Q4 OR Q5)
  createdAt DateTime @default(now())

  questions MidExamQuestion[]
}

// Subquestions (a, b, c) with CO mapping
model MidExamSubQuestion {
  id           String   @id @default(uuid())
  questionId   String
  subLabel     String   // "a", "b", "c"
  questionText String
  maxMarks     Float
  coMapping    String   @default("CO1") // CO1–CO10
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  question     MidExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  marksEntries MidExamMarksEntry[]

  @@unique([questionId, subLabel])
}

// Per-student marks entry (one row per student per paper)
model MidExamMarksEntry {
  id            String   @id @default(uuid())
  paperId       String
  studentId     String
  subQuestionId String
  marksObtained Float?   // null = not entered yet
  isAbsent      Boolean  @default(false)
  isDraft       Boolean  @default(true)
  enteredById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paper       MidExamPaper       @relation(fields: [paperId], references: [id], onDelete: Cascade)
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subQuestion MidExamSubQuestion @relation(fields: [subQuestionId], references: [id], onDelete: Cascade)

  @@unique([paperId, studentId, subQuestionId])
  @@index([paperId, studentId])
}

// Individual assignment marks per student per subject per academic class
model AssignmentMark {
  id             String   @id @default(uuid())
  academicYearId String
  departmentId   String
  year           String
  semester       String
  sectionId      String
  subjectId      String
  studentId      String
  marksObtained  Float
  maxMarks       Float    @default(10)
  enteredById    String
  isDraft        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, departmentId, year, semester, sectionId, subjectId, studentId])
  @@index([academicYearId, departmentId, year, semester, sectionId])
}

// Lock/publish state per paper — controls when data writes to InternalMark
model MidExamPublish {
  id             String    @id @default(uuid())
  paperId        String    @unique
  isLocked       Boolean   @default(false)
  lockedAt       DateTime?
  lockedById     String?
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  publishedById  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  paper          MidExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
}
