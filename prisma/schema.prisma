generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id         String              @id @default(uuid())
  name       String              @unique
  code       String              @unique
  isAcademic Boolean             @default(true)
  createdAt  DateTime            @default(now())
  alumni     Alumni[]
  history    AttendanceHistory[]
  faculty    Faculty[]
  labBatches LabBatch[]
  students   Student[]
  subjects   Subject[]
  users      User[]
  sections   Section[]           @relation("DepartmentToSection")
}

model Section {
  id          String              @id @default(uuid())
  name        String              @unique
  createdAt   DateTime            @default(now())
  history     AttendanceHistory[]
  labBatches  LabBatch[]
  students    Student[]
  departments Department[]        @relation("DepartmentToSection")
}

model User {
  id                    String                 @id @default(uuid())
  username              String                 @unique
  password              String
  role                  String                 @default("USER")
  departmentId          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  facultyId             String?                @unique
  downloads             AttendanceHistory[]
  passwordResetRequests PasswordResetRequest[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  faculty               Faculty?               @relation(fields: [facultyId], references: [id])
}

model Faculty {
  id            String     @id @default(uuid())
  empCode       String     @unique
  empName       String
  shortName     String?
  dob           DateTime
  gender        String
  joinDate      DateTime
  resignDate    DateTime?
  departmentId  String
  designation   String
  mobile        String
  email         String?
  bloodGroup    String?
  basicSalary   Float?
  fatherName    String?
  motherName    String?
  address       String?
  qualification String?
  aadharNo      String?
  panNo         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  department    Department @relation(fields: [departmentId], references: [id])
  user          User?
}

model Student {
  id                    String           @id @default(uuid())
  rollNumber            String           @unique
  name                  String
  mobile                String
  year                  String
  semester              String
  batchString           String?          @map("batch")
  sectionId             String
  departmentId          String
  regulationId          String?
  batchId               String?
  isDetained            Boolean          @default(false)
  originalBatchId       String?
  labBatchId            String?
  photoUrl              String?
  hallTicketNumber      String?          @unique
  eamcetRank            String?
  dateOfBirth           DateTime?
  dateOfReporting       DateTime?
  gender                String?
  caste                 String?
  casteName             String?
  category              String?
  admissionType         String?
  fatherName            String?
  motherName            String?
  address               String?
  studentContactNumber  String?
  emailId               String?
  aadharNumber          String?
  abcId                 String?
  reimbursement         Boolean          @default(false)
  isLateralEntry        Boolean          @default(false)
  certificatesSubmitted Boolean          @default(false)
  domainMailId          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  results               SemesterResult[]
  batch                 Batch?           @relation("CurrentBatch", fields: [batchId], references: [id])
  department            Department       @relation(fields: [departmentId], references: [id])
  labBatch              LabBatch?        @relation(fields: [labBatchId], references: [id])
  originalBatch         Batch?           @relation("OriginalBatch", fields: [originalBatchId], references: [id])
  regulation            Regulation?      @relation(fields: [regulationId], references: [id])
  section               Section          @relation(fields: [sectionId], references: [id])
  subjects              Subject[]        @relation("StudentToSubject")
}

model SemesterResult {
  id        String   @id @default(uuid())
  studentId String
  year      String
  semester  String
  sgpa      String
  cgpa      String
  grades    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, year, semester])
}

model Regulation {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  students  Student[]
  subjects  Subject[]
}

model Subject {
  id                   String              @id @default(uuid())
  name                 String
  code                 String
  year                 String
  semester             String
  type                 String
  isElective           Boolean             @default(false)
  regulationId         String?
  electiveSlotId       String?
  departmentId         String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  shortName            String?
  history              AttendanceHistory[]
  department           Department          @relation(fields: [departmentId], references: [id])
  electiveSlotRelation ElectiveSlot?       @relation(fields: [electiveSlotId], references: [id])
  regulation           Regulation?         @relation(fields: [regulationId], references: [id])
  students             Student[]           @relation("StudentToSubject")
}

model Period {
  id        String              @id @default(uuid())
  name      String
  startTime String
  endTime   String
  order     Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  history   AttendanceHistory[]
}

model AttendanceHistory {
  id             String        @id @default(uuid())
  date           DateTime      @default(now())
  year           String
  semester       String
  sectionId      String
  departmentId   String
  academicYearId String?
  subjectId      String?
  periodId       String?
  status         String
  type           String        @default("ACADEMIC")
  fileName       String?
  downloadedBy   String
  details        String        @default("[]")
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  department     Department    @relation(fields: [departmentId], references: [id])
  user           User          @relation(fields: [downloadedBy], references: [id])
  period         Period?       @relation(fields: [periodId], references: [id])
  section        Section       @relation(fields: [sectionId], references: [id])
  subject        Subject?      @relation(fields: [subjectId], references: [id])

  @@unique([date, sectionId, periodId], name: "unique_attendance")
}

model Alumni {
  id           String      @id @default(uuid())
  rollNumber   String      @unique
  name         String
  mobile       String
  passingYear  String
  departmentId String?
  createdAt    DateTime    @default(now())
  department   Department? @relation(fields: [departmentId], references: [id])
}

model ElectiveSlot {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  subjects  Subject[]
}

model AcademicYear {
  id                String              @id @default(uuid())
  name              String              @unique
  startDate         DateTime
  endDate           DateTime
  isCurrent         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attendanceHistory AttendanceHistory[]
}

model Batch {
  id               String    @id @default(uuid())
  name             String    @unique
  startYear        Int
  endYear          Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  students         Student[] @relation("CurrentBatch")
  detainedStudents Student[] @relation("OriginalBatch")
}

model LabBatch {
  id           String     @id @default(uuid())
  name         String
  sectionId    String
  departmentId String
  year         String
  semester     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
  section      Section    @relation(fields: [sectionId], references: [id])
  students     Student[]

  @@unique([departmentId, year, semester, sectionId, name])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entity      String
  entityId    String?
  details     String
  performedBy String
  createdAt   DateTime @default(now())
}

model PasswordResetRequest {
  id         String   @id @default(uuid())
  userId     String
  status     String   @default("PENDING")
  resolvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}
