generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique // CSE, CSM
  code      String   @unique
  createdAt DateTime @default(now())
  
  users     User[]
  students  Student[]
  history   AttendanceHistory[]
  alumni    Alumni[]
  
  sections  Section[] // Many-to-Many
  subjects  Subject[]
}

model Section {
  id        String   @id @default(uuid())
  name      String   @unique // A, B, C
  createdAt DateTime @default(now())

  students  Student[]
  history   AttendanceHistory[]
  
  departments Department[] // Many-to-Many
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  role         String   @default("USER") // ADMIN, USER, HOD
  
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  downloads    AttendanceHistory[]
}

model Student {
  id           String   @id @default(uuid())
  rollNumber   String   @unique
  name         String
  mobile       String
  year         String
  semester     String
  
  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  
  regulationId String?
  regulation   Regulation? @relation(fields: [regulationId], references: [id])

  subjects     Subject[] // Many-to-Many for Electives

  photoUrl     String? // URL or Path to student photo

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  results    SemesterResult[]
}

model SemesterResult {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  
  year      String   // "1", "2"
  semester  String   // "1", "2"
  
  sgpa      String   // "9.5", "Failed"
  cgpa      String   // "8.9"
  
  grades    Json     // [{ subjectCode: "CS101", subjectName: "Java", grade: "O" }]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, year, semester])
}

model Regulation {
  id        String   @id @default(uuid())
  name      String   @unique // "R20", "R22"
  createdAt DateTime @default(now())
  
  students  Student[]
  subjects  Subject[]
}

model Subject {
  id           String   @id @default(uuid())
  name         String
  code         String   // Unique per Dept theoretically, but keeping simple for now
  year         String
  semester     String
  type         String   // "THEORY" | "LAB"
  isElective   Boolean  @default(false)
  
  regulationId String?
  regulation   Regulation? @relation(fields: [regulationId], references: [id])

  electiveSlot String?  // "PE-1", "OE-1", "PE-2", etc.

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  
  history      AttendanceHistory[]
  students     Student[] // Many-to-Many for Electives

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Period {
  id        String   @id @default(uuid())
  name      String   // "1st Hour", "2nd Hour"
  startTime String   // "08:40 AM"
  endTime   String   // "09:30 AM"
  order     Int      // For sorting
  
  history   AttendanceHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Updated Attendance History
// Note: We keep old fields valid, but new ones will use subjectId/periodId
model AttendanceHistory {
  id           String   @id @default(uuid())
  date         DateTime @default(now())
  year         String
  semester     String
  
  sectionId    String
  section      Section @relation(fields: [sectionId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  // New Relations (Optional for backward compatibility)
  subjectId    String?
  subject      Subject? @relation(fields: [subjectId], references: [id])

  periodId     String?
  period       Period?  @relation(fields: [periodId], references: [id])

  status       String   // "Marked Present" or "Marked Absent"
  fileName     String
  downloadedBy String
  user         User     @relation(fields: [downloadedBy], references: [id])
  details      String   @default("[]") // JSON string of student data for re-download
}

model Alumni {
  id          String   @id @default(uuid())
  rollNumber  String   @unique
  name        String
  mobile      String
  passingYear String   // e.g., "2024"
  
  departmentId String? // Made optional for flexibility, but seed will populate
  department   Department? @relation(fields: [departmentId], references: [id])

  createdAt   DateTime @default(now())
}
